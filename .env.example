# Myastro — environment variables (template)
# =============================================================================
# Copy this file to ".env" and fill in real values. ".env" is gitignored — it
# NEVER gets committed. The backend reads these from the environment first, then
# falls back to .streamlit/secrets.toml for local Streamlit dev.
#
# Where to find the Supabase values:
#   Supabase dashboard → Project Settings → API
#     • Project URL          → SUPABASE_URL
#     • Project API keys → anon / public      → SUPABASE_ANON_KEY
#     • Project API keys → service_role secret → SUPABASE_SERVICE_ROLE_KEY
# =============================================================================

# ── Supabase (data layer) ────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key            # safe for the app; RLS protects data
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER-ONLY — never ship to the app

# ── AI providers (already used by the backend) ───────────────────────────────
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ── RAG vector store ─────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── Geocoding (place name → lat/lon) — Nominatim-compatible ──────────────────
# Two ways, pick one (NOMINATIM_URL wins if both set):
#   1) Self-hosted Nominatim (endgame, e.g. on the Oracle box): full OSM, no
#      vendor, only the standard "© OpenStreetMap" data credit, $0.
NOMINATIM_URL=                 # e.g. http://127.0.0.1:8080  (leave blank if unused)
#   2) LocationIQ free tier (full OSM; commercial use OK on the free tier but it
#      REQUIRES a "Search by LocationIQ" backlink — put it in your About/Credits
#      screen and confirm acceptable with LocationIQ support). Key from locationiq.com.
LOCATIONIQ_API_KEY=
# Without either, geocoding falls back to Photon (NON-commercial, dev only).
