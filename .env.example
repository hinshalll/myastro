# Myastro — environment variables (template)
# =============================================================================
# Copy this file to ".env" and fill in real values. ".env" is gitignored — it
# NEVER gets committed. The backend reads these from the environment first, then
# falls back to .streamlit/secrets.toml for local Streamlit dev.
#
# Where to find the Supabase values:
#   Supabase dashboard → Project Settings → API
#     • Project URL          → SUPABASE_URL
#     • Project API keys → anon / public      → SUPABASE_ANON_KEY
#     • Project API keys → service_role secret → SUPABASE_SERVICE_ROLE_KEY
# =============================================================================

# ── Supabase (data layer) ────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key            # safe for the app; RLS protects data
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER-ONLY — never ship to the app

# ── AI providers (already used by the backend) ───────────────────────────────
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ── RAG vector store ─────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── Geocoding (place name → lat/lon) ─────────────────────────────────────────
# OpenCage free tier (2,500/day, COMMERCIAL use OK, results may be stored, and
# NO OpenCage-brand attribution required — only a standard "© OpenStreetMap"
# data credit). Sign up free (no credit card) at https://opencagedata.com → key.
# REQUIRED in production — without it, geocoding falls back to Photon, which is
# NOT licensed for commercial use.
OPENCAGE_API_KEY=
