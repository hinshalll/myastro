# Keep the API image small + the build fast. Exclude everything the FastAPI
# backend doesn't need at runtime. The chart engine is the free Skyfield engine
# (de440s.bsp JPL kernel, baked in by the Dockerfile) — it does NOT use the old
# Swiss Ephemeris ephe/ data, so that is excluded below.

.git
.github
.devcontainer
.claude
.venv
__pycache__
**/__pycache__
*.pyc
*.pyo
*.log

# Frontend + old prototypes (not used by the API)
mobile
web
ui_streamlit
design_import
node_modules

# Swiss Ephemeris data — no longer used by the runtime (the free Skyfield engine
# replaced it). Kept in the repo only for the local dev validation reference.
ephe

# Local secrets — env vars are set in the Render dashboard instead
.streamlit/secrets.toml
