# Copy this file to .streamlit/secrets.toml and fill in your real values.
# .streamlit/secrets.toml is gitignored — never commit it.
#
# Streamlit Cloud reads these from the UI "Secrets" panel instead of this file.
# Render / FastAPI reads them from environment variables with the same names.

GEMINI_API_KEY  = "your-google-genai-api-key-from-aistudio.google.com"
QDRANT_URL      = "https://your-cluster-id.qdrant.io"
QDRANT_API_KEY  = "your-qdrant-api-key"
