{
  "expo": {
    "name": "Myastro",
    "slug": "myastro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myastro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.myastro.app"
    },
    "android": {
      "package": "com.myastro.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
